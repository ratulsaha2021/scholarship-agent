  "sentence_patterns": [
    "^[A-Z][a-z]+(?:ly)?,?\\s",
    "(?:Furthermore|Moreover|Additionally|Consequently),?\\s",
    "(?:It is|There is|It's worth) (?:important|crucial|essential) to",
    "(?:I am|I'm) writing to (?:express|inquire|apply)",
    "(?:I believe|I think|In my opinion) that"
